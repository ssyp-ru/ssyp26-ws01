assert 2 == 2;
assert 2 + 2 == 4;
assert 2 + 2 * 2 == 6;

assert 1 < 2;
assert 2 > 1;
assert 1 >= 1;
assert 1 <= 1;
assert 2 >= 1;
assert 1 <= 2;

let answer = 40;
assert answer == 40;
answer = answer + 2;
assert answer == 42;

let left = 1;
let right = 2;
left = right = 3;
assert left == 3;
assert right == 3;

fn add(left, right) {
    let result = left + right;
    return result;
}

assert add(20, 22) == 42;
assert add(1, 2) == 3;

let base = 10;
fn increment(value) {
    let result = value + base;
    return result;
}

assert increment(2) == 12;

fn twice(value) {
    return add(value, value);
}

assert twice(21) == 42;

if (2 + 2 == 4) {
    print 1;
}

if (2 + 2 == 4) {
    print 2;
} else {
    assert false;
}

if (2 + 2 == 5) {
    assert false;
} else {
    print 2;
}

if (2 + 2 == 5) {
    assert false;
}

if (2 + 2 == 3) {
    assert false;
} else if (2 + 2 == 5) {
    assert false;
} else {
    print 3;
}

if (2 + 2 == 3) {
    assert false;
} else if (2 + 2 == 5) {
    assert false;
} else if (2 + 2 == 4) {
    print 4;
} else {
    assert false;
}

let count = 0;
while (count < 10) {
    print count;
    count = count + 1;
}

print "strings!!!!!!!";
assert "abc" == "abc";
assert "abc" != "bcd";
assert "abc" != "abcd";

let a = object();
a[10] = 2;
a[0] = "hello";
a[1] = "world";
a[2] = 0;
a[3] = 1;
let b = object();
b["a"] = 3;
b[1] = "a";
assert a[10] == 2;
assert b["a"] == 3;

for (let i = 0; i < 10; i = i + 1) {
    print i;
}

let obj_1 = object();
obj_1["blahblah"] = 123;
obj_1[600] = 333;
obj_1[444] = "aaaaa";
obj_1["ggggg"] = "ffffff";

let obj_2 = object();
obj_2["blahblah"] = 123;
obj_2[600] = 333;
obj_2[444] = "aaaaa";
obj_2["ggggg"] = "ffffff";

let obj_3 = object();
obj_3["blahblah"] = 123;
obj_3[600] = 333;
obj_3["extra_entry"] = 1;
obj_3[444] = "aaaaa";
obj_3["ggggg"] = "ffffff";

assert obj_1 == obj_2;
assert obj_1 != obj_3;

