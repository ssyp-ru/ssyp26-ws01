assert 2 == 2;
assert 2 + 2 == 4;
assert 2 + 2 * 2 == 6;

assert 1 < 2;
assert 2 > 1;
assert 1 >= 1;
assert 1 <= 1;
assert 2 >= 1;
assert 1 <= 2;

let answer = 40;
assert answer == 40;
answer = answer + 2;
assert answer == 42;

let left = 1;
let right = 2;
left = right = 3;
assert left == 3;
assert right == 3;

fn add(left, right) {
    let result = left + right;
    return result;
}

assert add(20, 22) == 42;
assert add(1, 2) == 3;

let base = 10;
fn increment(value) {
    let result = value + base;
    return result;
}

assert increment(2) == 12;

fn twice(value) {
    return add(value, value);
}

assert twice(21) == 42;

if (2 + 2 == 4) {
    print 1;
}

if (2 + 2 == 4) {
    print 2;
} else {
    assert false;
}

if (2 + 2 == 5) {
    assert false;
} else {
    print 2;
}

if (2 + 2 == 5) {
    assert false;
}

if (2 + 2 == 3) {
    assert false;
} else if (2 + 2 == 5) {
    assert false;
} else {
    print 3;
}

if (2 + 2 == 3) {
    assert false;
} else if (2 + 2 == 5) {
    assert false;
} else if (2 + 2 == 4) {
    print 4;
} else {
    assert false;
}

