assert 2 == 2;
assert 2 + 2 == 4;
assert 2 + 2 * 2 == 6;

assert 1 < 2;
assert 2 > 1;
assert 1 >= 1;
assert 1 <= 1;
assert 2 >= 1;
assert 1 <= 2;

let answer = 40;
assert answer == 40;
answer = answer + 2;
assert answer == 42;

let left = 1;
let right = 2;
left = right = 3;
assert left == 3;
assert right == 3;

